generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  email             String?           @unique
  name              String?
  bizboxUsername    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  companies         UserCompany[]
  invoiceDrafts     InvoiceDraft[]
  settings          UserSettings?
  localSentInvoices LocalSentInvoice[]

  @@index([createdAt])
  @@index([updatedAt])
}

model Company {
  id                String            @id @default(cuid())
  name              String
  vatNumber         String?
  taxId             String?
  registrationNumber String?
  eLocation         String?
  eAddress          String?
  address           String?
  postCode          String?
  city              String?
  country           String?           @default("SI")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  users             UserCompany[]
  invoiceDrafts     InvoiceDraft[]
  localSentInvoices LocalSentInvoice[]

  @@index([vatNumber])
  @@index([taxId])
  @@index([createdAt])
  @@index([updatedAt])
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
  @@index([updatedAt])
}

model InvoiceDraft {
  id             String   @id @default(cuid())
  userId         String
  companyId      String
  documentNumber String?
  profile        String?
  buyerName      String?
  buyerVat       String?
  grossAmount    Decimal? @db.Decimal(14, 2)
  currency       String   @default("EUR")
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([documentNumber])
  @@index([createdAt])
  @@index([updatedAt])
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([updatedAt])
}

model LocalSentInvoice {
  id             String   @id @default(cuid())
  userId         String
  companyId      String
  documentNumber String?
  bizboxDocumentId String?
  profile        String?
  buyerName      String?
  buyerVat       String?
  grossAmount    Decimal? @db.Decimal(14, 2)
  currency       String   @default("EUR")
  status         String?
  sentAt         DateTime?
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([documentNumber])
  @@index([createdAt])
  @@index([updatedAt])
}
